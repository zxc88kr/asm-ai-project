# Backend
APP_NAME=리뷰 대응 에이전트
ENVIRONMENT=local
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
MYSQL_DATABASE=review_helper
MYSQL_USER=review_user
MYSQL_PASSWORD=review_password
MYSQL_ROOT_PASSWORD=review_root_password
DATABASE_URL=mysql+pymysql://review_user:review_password@localhost:3306/review_helper
CREATE_TABLES_ON_STARTUP=true
RESET_DATABASE_ON_STARTUP=true
SEED_ON_STARTUP=true
SEED_RAG_ON_STARTUP=true

# AI / RAG
# AI_MODE는 모호한 자동 전환 없이 명시적으로 선택합니다.
# mock = 외부 API 호출 없이 로컬 deterministic mock 사용
# live = 실제 Upstage API 호출, UPSTAGE_API_KEY 필수
AI_MODE=mock
UPSTAGE_API_KEY=
UPSTAGE_BASE_URL=https://api.upstage.ai/v1
UPSTAGE_CHAT_MODEL=solar-pro
UPSTAGE_EMBEDDING_MODEL=embedding-query
AI_TIMEOUT_SECONDS=30
CHROMA_PERSIST_DIR=.chroma
RAG_COLLECTION_NAME=review_reply_pairs

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_BASE_URL=ws://localhost:8000