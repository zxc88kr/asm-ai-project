# 추천 후보 카탈로그 경로 (repo 루트 기준)
CATALOG_PATH=ai/data/samples/melon_kpop_sample.jsonl

# 로컬 개발: iTunes 실존 검증/선호 확장 LLM 호출을 건너뛴다(네트워크/키 없이 구동).
# 운영에서는 1로 두지 말 것.
AI_SKIP_ITUNES_VERIFICATION=1
AI_SKIP_PREFERENCE_EXPANSION=1

# Upstage Solar 키는 ai/.env 에 둔다(추천모듈이 거기서 읽음).
# 실제 추천(LLM 후보 선별)에는 키가 필요하다.
# UPSTAGE_API_KEY=your-api-key
