# Required: Upstage API key for character chat and deduction evaluation.
UPSTAGE_API_KEY=your-upstage-api-key

# Optional: defaults used by agents/adapters.py.
UPSTAGE_BASE_URL=https://api.upstage.ai/v1
UPSTAGE_MODEL=solar-pro3

# CORS origins. Use comma-separated origins when multiple clients need access.
CLIENT_ORIGIN_URL=http://localhost:3000

# Reverse proxy IPs allowed to provide X-Forwarded-* headers.
# Set both values to the Nginx Proxy Manager container IP/subnet in deployment.
TRUSTED_PROXY_IPS=172.18.0.0/16
FORWARDED_ALLOW_IPS=172.18.0.0/16
